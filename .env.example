# =====================================================
# TaskFlow 部署环境变量
# 复制为 .env 后修改各项值
# 配合 docker-compose.yml 使用
# =====================================================

# ---------- 暴露端口 ----------
FRONTEND_PORT=80
# BACKEND_PORT=3000     # 仅当你需要在宿主机直连后端时取消注释 docker-compose.yml 中相应端口
# MYSQL_PORT=3306       # 同上

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=please_change_this_strong_password
MYSQL_DATABASE=ai_task_manager

# ---------- JWT ----------
# 用一段长随机字符串，例如 `openssl rand -hex 32`
JWT_SECRET=please_change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ---------- AI 服务（Claude 兼容 OpenAI 协议）----------
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 注意：必须包含 /v1
AI_BASE_URL=https://api.openai-sb.com/v1
AI_MODEL=claude-3-5-sonnet-20241022
AI_TIMEOUT_MS=60000
