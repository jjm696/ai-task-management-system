// =====================================================
// TaskFlow Prisma Schema
// 文档：https://pris.ly/d/prisma-schema
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ----------------- 枚举 -----------------

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

// ----------------- 用户 -----------------

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   // 存储 bcrypt 加密后的哈希
  nickname  String   @db.VarChar(50)
  avatar    String?  @db.VarChar(255)
  createdAt DateTime @default(now())

  tasks      Task[]
  dailyPlans DailyPlan[]

  @@map("users")
}

// ----------------- 任务 -----------------

model Task {
  id             Int        @id @default(autoincrement())
  title          String     @db.VarChar(200)
  description    String?    @db.Text
  priority       Priority   @default(MEDIUM)
  status         TaskStatus @default(PENDING)
  dueDate        DateTime?
  estimatedHours Float?
  aiGenerated    Boolean    @default(false)
  sourcePrompt   String?    @db.Text
  completedAt    DateTime?

  parentId Int?
  parent   Task?  @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks Task[] @relation("TaskSubtasks")

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  dailyPlanItems DailyPlanItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([parentId])
  @@index([status])
  @@index([dueDate])
  @@index([completedAt])
  @@map("tasks")
}

// ----------------- 每日计划 -----------------

model DailyPlan {
  id      Int      @id @default(autoincrement())
  date    DateTime @db.Date
  summary String?  @db.Text

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  items DailyPlanItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("daily_plans")
}

model DailyPlanItem {
  id             Int         @id @default(autoincrement())
  order          Int         @default(0)
  note           String?     @db.Text
  statusSnapshot TaskStatus?

  dailyPlanId Int
  dailyPlan   DailyPlan @relation(fields: [dailyPlanId], references: [id], onDelete: Cascade)

  taskId Int
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dailyPlanId, taskId])
  @@index([taskId])
  @@map("daily_plan_items")
}
